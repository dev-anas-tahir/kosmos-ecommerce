# ========================================
# Application Settings
# ========================================
APP_NAME=iam-service
APP_ENV=development         # fix: secure=False on cookie, docs visible
APP_DEBUG=true              # use structured logs so LOG_LEVEL is respected
LOG_LEVEL=DEBUG             # see everything during development

# ========================================
# Database Configuration
# ========================================
DATABASE_URL=postgresql+asyncpg://user:password@host:port/iam
TEST_DATABASE_URL=postgresql+asyncpg://user:password@host:port/iam-test
POOL_SIZE=10
MAX_OVERFLOW=20

# ========================================
# Redis Configuration
# ========================================
REDIS_URL=redis://user:password@host:port

# ========================================
# JWT Configuration
# ========================================
JWT_ALGORITHM=RS256
JWT_ISSUER=iam-service
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
PRIVATE_KEY_PATH=keys/private_key.pem
PUBLIC_KEY_PATH=keys/public_key.pem

# ========================================
# GCP Configuration
# ========================================
GCP_PROJECT_ID=your-gcp-project-id
PUBSUB_TOPIC_ID=your-pubsub-topic

# ========================================
# Seed Script (scripts/seed.py)
# ========================================
# Required to seed the initial super_user. Leave blank to skip.
SEED_ADMIN_USERNAME=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_EMAIL=
