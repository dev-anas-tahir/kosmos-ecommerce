# ========================================
# Application Settings
# ========================================
APP_NAME=catalog-service
APP_ENV=development        # fix: secure=False on cookie, docs visible
APP_DEBUG=true             # use structured logs so LOG_LEVEL is respected
LOG_LEVEL=DEBUG             # see everything during development

# ========================================
# Database Configuration
# ========================================
DATABASE_URL=postgresql+asyncpg://user:password@host:port//catalog
TEST_DATABASE_URL=postgresql+asyncpg://user:password@host:port/catalog_test
POOL_SIZE=10
MAX_OVERFLOW=20

# ========================================
# JWT Configuration
# ========================================
IAM_JWKS_URL=http://iam-service-host:8000/.well-known/jwks.json

# ========================================
# GCP Configuration
# ========================================
GCP_PROJECT_ID=your-gcp-project-id
PUBSUB_TOPIC_ID=your-pubsub-topic
