# Backend service base URLs — server-side only. Never expose to client JS (no NEXT_PUBLIC_ prefix).
# Route Handlers and Server Components in apps/web/ proxy to these per ADR-007.
IAM_SERVICE_URL=http://localhost:8000
CATALOG_SERVICE_URL=http://localhost:8001
ORDER_SERVICE_URL=http://localhost:8002

# JWKS endpoint for verifying access tokens server-side. Public per ADR-006.
IAM_JWKS_URL=http://localhost:8000/.well-known/jwks.json
